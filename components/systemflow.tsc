"use client"

import { motion } from "framer-motion"

const FLOW_STEPS = [
  {
    title: "User Input",
    desc: "User sends request or context to AI system",
  },
  {
    title: "Abraham Memory Engine",
    desc: "Stores identity, context, and session state",
  },
  {
    title: "Context Retrieval Layer",
    desc: "Retrieves relevant long-term memory",
  },
  {
    title: "Model Router",
    desc: "Selects OpenAI or Claude based on context",
  },
  {
    title: "AI Response Generation",
    desc: "Model generates response with memory context",
  },
  {
    title: "Memory Update",
    desc: "New state is stored back into memory layer",
  },
]

export function SystemFlow() {
  return (
    <section id="system" className="relative py-24">
      <div className="mx-auto max-w-5xl px-4 lg:px-6">

        {/* HEADER */}
        <motion.div
          initial={{ opacity: 0, y: 16 }}
          whileInView={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.6 }}
          viewport={{ once: true }}
          className="text-center"
        >
          <h2 className="text-3xl font-semibold tracking-tight sm:text-4xl">
            AI Memory System Flow
          </h2>

          <p className="mt-4 text-muted-foreground">
            How Abraham Memory connects AI models with persistent memory infrastructure.
          </p>
        </motion.div>

        {/* FLOW */}
        <div className="mt-14 space-y-6">
          {FLOW_STEPS.map((step, i) => (
            <motion.div
              key={step.title}
              initial={{ opacity: 0, x: -20 }}
              whileInView={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.5, delay: i * 0.08 }}
              viewport={{ once: true }}
              className="relative rounded-xl border border-border bg-card/60 p-5 backdrop-blur"
            >
              {/* connector line */}
              {i !== FLOW_STEPS.length - 1 && (
                <div className="absolute left-6 top-14 h-10 w-px bg-border" />
              )}

              <div className="flex items-start gap-4">
                {/* step number */}
                <div className="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-sm font-medium text-primary">
                  {i + 1}
                </div>

                {/* content */}
                <div>
                  <h3 className="text-base font-medium">{step.title}</h3>
                  <p className="mt-1 text-sm text-muted-foreground">
                    {step.desc}
                  </p>
                </div>
              </div>
            </motion.div>
          ))}
        </div>

        {/* SYSTEM NOTE */}
        <div className="mt-12 text-center text-xs text-muted-foreground">
          OpenAI • Claude • Abraham Memory Engine — unified through memory persistence layer
        </div>
      </div>
    </section>
  )
}